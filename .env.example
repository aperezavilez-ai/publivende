# URL pública de la app (sin barra final)
# Local: http://localhost:8083  |  TikTok OAuth: http://127.0.0.1:8083  |  TikTok formularios: https://TU-NGROK.ngrok-free.app
VITE_APP_URL=http://localhost:8083

# Secreto para firmar el parámetro state de OAuth (genera uno aleatorio)
OAUTH_STATE_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- Meta (Facebook + Instagram) ---
# https://developers.facebook.com/apps → Crear app → Facebook Login
# Redirect URI válido: http://localhost:8083/oauth/callback/meta
META_APP_ID=
META_APP_SECRET=

# --- Google (YouTube) ---
# https://console.cloud.google.com/apis/credentials
# Redirect URI: http://localhost:8083/oauth/callback/google
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- TikTok ---
# https://developers.tiktok.com/
# Redirect URI: http://localhost:8083/oauth/callback/tiktok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# Production (Vercel): set all vars in Project → Settings → Environment Variables
# VITE_APP_URL=https://publivende.vercel.app

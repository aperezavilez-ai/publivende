# URL pública de la app (sin barra final)
VITE_APP_URL=http://localhost:8083

# === PRODUCCIÓN (obligatorio para modo real) ===
# Supabase/Neon Postgres connection string
DATABASE_URL=
# Secreto JWT sesiones (min 32 caracteres aleatorios)
SESSION_SECRET=

# OAuth state signing
OAUTH_STATE_SECRET=cambia-esto-por-un-secreto-largo-y-aleatorio

# --- Meta (Facebook + Instagram + WhatsApp) ---
META_APP_ID=
META_APP_SECRET=

# --- Google (YouTube) ---
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# --- TikTok ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# --- WhatsApp Cloud API (plataforma / fallback admin) ---
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=publivende_verify
# UUID del usuario admin (solo fallback legacy si no hay multi-tenant)
WHATSAPP_DEFAULT_USER_ID=

# --- WhatsApp Embedded Signup (cada cliente conecta SU número) ---
# Configuration ID desde Meta → WhatsApp → Embedded Signup
WHATSAPP_EMBEDDED_SIGNUP_CONFIG_ID=

# --- IA (OpenAI) ---
OPENAI_API_KEY=

# --- Pagos (Stripe — principal) ---
STRIPE_SECRET_KEY=sk_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...  # futuro: confirmación de pagos

# --- MercadoPago (opcional, LATAM) ---
# MERCADOPAGO_ACCESS_TOKEN=

# --- Plataforma API (marca blanca / otros proyectos) ---
# Partners y API keys se gestionan en /plataforma (admin). Formato key: pv_live_...

# Production (Vercel): set all vars in Project → Settings → Environment Variables
VITE_APP_URL=https://publivende.mx
